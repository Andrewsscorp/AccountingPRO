generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-global"
}

datasource db {
  provider = "sqlite"
  url      = env("GLOBAL_DATABASE_URL")
}

model EmpresaGlobal {
  id             Int      @id @default(autoincrement())
  codigo_empresa String   @unique
  nombre_empresa String
  nit            String
  servidor_bd    String
  nombre_bd      String
  estado         String   @default("ACTIVO")
  fecha_creacion DateTime @default(now())

  usuarios       UsuarioEmpresa[]
}

model Ciiu {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  descripcion String
  tarifaIca   Float?   // Tarifa ICA referencial (e.g. 9.66)
  createdAt   DateTime @default(now())
}

model Usuario {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  nombre       String
  rol          String   @default("USER") // Rol global
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  empresas     UsuarioEmpresa[]
  refreshTokens RefreshToken[]
}

model UsuarioEmpresa {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  empresaId Int
  rol       String   @default("CONTADOR") // Rol en la empresa (ej. ADMIN, CONTADOR, LECTOR)
  createdAt DateTime @default(now())

  usuario   Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa   EmpresaGlobal @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, empresaId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  revocado  Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario   Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
}
